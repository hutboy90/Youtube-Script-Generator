{
  "manifest_version": 3,
  "name": "YT Subtitle Downloader",
  "version": "1.0.0",
  "description": "Download subtitles from YouTube videos in TXT, SRT, or VTT format",
  "permissions": ["activeTab", "scripting", "downloads", "tabs"],
  "host_permissions": ["https://www.youtube.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  }
}
